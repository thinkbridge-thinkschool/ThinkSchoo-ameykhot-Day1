{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=quotes.db"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "ServiceBus": {
    "ConnectionString": ""
  },
  "KeyVault": {
    "Url": "https://quotesapp-kv-amey.vault.azure.net/"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Jwt": {
    "Key": "ThinkSchoolDay2JwtSigningKey-UseAtLeast32Chars",
    "Audience": "",
    "AccessTokenLifetime": "00:15:00"
  },
  "EntraId": {
    "TenantId": "29483a98-f908-4076-94c2-a30a84723e0d",
    "ClientId": "placeholder-update-after-deploy",
    "Audience": "api://placeholder-update-after-deploy"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{TraceId}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
